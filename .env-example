# PageSquad AI Skills - Environment Variables Example
# Copy this file to .env and fill in your actual keys.
# Do NOT commit your actual .env file to version control.

# --- Visibility Architect ---
# Required for running the pagespeed-audit utility scripts
PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# --- Automation Architect (Example Placeholders) ---
# Used for connecting CRM systems and webhooks
# HUBSPOT_API_KEY=your_hubspot_api_key_here
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# --- Insight Architect (Example Placeholders) ---
# Used for analytics and tracking validations
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GTM_CONTAINER_ID=GTM-XXXXXX
# META_PIXEL_ID=XXXXXXXXXXXXXXX
# TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXXXX

# --- AI & Asset Generation (Example Placeholders) ---
# Common keys that might be used by Brand or Conversion architects
# OPENAI_API_KEY=sk-your_openai_api_key_here
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
